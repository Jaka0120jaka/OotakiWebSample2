@using OotakiWebSample2.Models
@model OotakiWebSample2.Models.ScreenViewModel
@{
    ViewData["Title"] = "Home Page";
}

<link href="~/css/style.css" rel="stylesheet" />
<style>
    .custom-table th {
        cursor: pointer;
        user-select: none;
        white-space: nowrap;
    }

    .custom-table th .th-inner {
        display: inline-flex;
        align-items: center;
        gap: 4px;
    }

    .sort-icon {
        display: inline-flex;
        flex-direction: column;
        gap: 1px;
        flex-shrink: 0;
    }

    .sort-icon svg {
        display: block;
    }

    /* 未ソート時：両矢印を薄く表示 */
    .sort-icon .icon-asc,
    .sort-icon .icon-desc {
        opacity: 0.3;
        transition: opacity 0.15s;
    }

    /* 昇順ソート中：上矢印を強調 */
    th[data-sort="asc"] .sort-icon .icon-asc {
        opacity: 1;
    }
    th[data-sort="asc"] .sort-icon .icon-desc {
        opacity: 0.2;
    }

    /* 降順ソート中：下矢印を強調 */
    th[data-sort="desc"] .sort-icon .icon-desc {
        opacity: 1;
    }
    th[data-sort="desc"] .sort-icon .icon-asc {
        opacity: 0.2;
    }
</style>

<div class="page-wrapper">
    <div class="table-wrapper">

        @* 表示設定ボタン：クリックで #listModal を開く *@
        <button class="btn btn-primary btn-settings"
                data-bs-toggle="modal"
                data-bs-target="#listModal"
                id="hyouji">
            表示設定
        </button>

        <!-- 横スクロールエリア：VisibleFlag が true の項目のみ列として表示 -->
        <div class="scroll-area">
            <table class="custom-table" id="sortableTable">
                <thead>
                    <tr>
                        @foreach (var item in Model.ListViewModels.Where(x => x.VisibleFlag))
                        {
                            <th data-col="@item.ItemName" data-sort="none">
                                <span class="th-inner">
                                    <span>@item.ItemName</span>
                                    <span class="sort-icon">
                                        @* 昇順アイコン（上向き三角） *@
                                        <svg class="icon-asc" width="8" height="5" viewBox="0 0 8 5" fill="currentColor">
                                            <path d="M4 0L8 5H0L4 0Z" />
                                        </svg>
                                        @* 降順アイコン（下向き三角） *@
                                        <svg class="icon-desc" width="8" height="5" viewBox="0 0 8 5" fill="currentColor">
                                            <path d="M4 5L0 0H8L4 5Z" />
                                        </svg>
                                    </span>
                                </span>
                            </th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @{
                        var maxRow = Model.ListViewModels.Max(x => x.Values.Count);
                    }
                    @for (int i = 0; i < maxRow; i++)
                    {
                        <tr>
                            @foreach (var item in Model.ListViewModels.Where(x => x.VisibleFlag))
                            {
                                <td data-col="@item.ItemName">
                                    @(item.Values.Count > i ? item.Values[i] : "")
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @*
            表示設定モーダル用の ViewModel を構築して部分ビューに渡す
            ListViewModels : モーダル内に表示する全項目
            ListModal      : モーダルの識別子
        *@
        @{
            var modalModel = new ListModalModel
            {
                ListViewModels = Model.ListViewModels,
                ListModal = "Screen1"
            };
        }
        <partial name="_ListModal" model="modalModel" />

    </div>
</div>
<script>
    // ===== 「適用」ボタン押下時の処理 =====
    document.querySelector('#listModal .btn-primary').addEventListener('click', async function () {
        const checkboxes = document.querySelectorAll('#listModal .form-check-input');
    
        // 全チェックボックスをループしてDB更新＆テーブル操作
        const promises = Array.from(checkboxes).map(chk => {
            const itemName = chk.dataset.item;
            const isChecked = chk.checked;

            // テーブルの列を表示/非表示
            const cols = document.querySelectorAll(`[data-col="${itemName}"]`);
            cols.forEach(col => col.style.display = isChecked ? '' : 'none');

            // DB更新（Ajax）
            return fetch('/Home/UpdateVisible', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    visibleFlg: isChecked,
                    itemName: itemName,
                    screenId: 1,  // 固定値：画面ID
                    userId: 1     // 固定値：ユーザーID
                })
            });
        });

        // 全件のDB更新が完了するまで待機
        await Promise.all(promises);

        // モーダルを閉じる
        bootstrap.Modal.getInstance(document.getElementById('listModal')).hide();
    });


    // ===== 降順・昇順ソート処理 =====

    (function () {
        const table = document.getElementById('sortableTable');
        if (!table) return;

        // オリジナルの行順を保持
        const tbody = table.querySelector('tbody');
        const originalRows = Array.from(tbody.querySelectorAll('tr'));

        table.querySelectorAll('thead th').forEach(function (th) {
            th.addEventListener('click', function () {
                const colName = th.getAttribute('data-col');
                const currentSort = th.getAttribute('data-sort');

                // ソート順を切り替え: none → asc → desc → none
                let nextSort;
                if (currentSort === 'none') {
                    nextSort = 'asc';
                } else if (currentSort === 'asc') {
                    nextSort = 'desc';
                } else {
                    nextSort = 'none';
                }

                // 全ヘッダーをリセット
                table.querySelectorAll('thead th').forEach(function (otherTh) {
                    otherTh.setAttribute('data-sort', 'none');
                });

                th.setAttribute('data-sort', nextSort);

                // 行を並べ替え
                let rows = Array.from(tbody.querySelectorAll('tr'));

                if (nextSort === 'none') {
                    // 元の順序に戻す
                    originalRows.forEach(function (row) {
                        tbody.appendChild(row);
                    });
                    return;
                }

                rows.sort(function (rowA, rowB) {
                    const cellA = rowA.querySelector('td[data-col="' + colName + '"]');
                    const cellB = rowB.querySelector('td[data-col="' + colName + '"]');
                    const valA = cellA ? cellA.textContent.trim() : '';
                    const valB = cellB ? cellB.textContent.trim() : '';

                    // 数値として比較できる場合は数値ソート
                    const numA = parseFloat(valA.replace(/,/g, ''));
                    const numB = parseFloat(valB.replace(/,/g, ''));

                    if (!isNaN(numA) && !isNaN(numB)) {
                        return nextSort === 'asc' ? numA - numB : numB - numA;
                    }

                    // 文字列ソート（日本語対応）
                    return nextSort === 'asc'
                        ? valA.localeCompare(valB, 'ja')
                        : valB.localeCompare(valA, 'ja');
                });

                rows.forEach(function (row) {
                    tbody.appendChild(row);
                });
            });
        });
    })();
</script>